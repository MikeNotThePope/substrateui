{
  "name": "@mikenotthepope/substrateui",
  "version": "1.1.0",
  "description": "A chunky, OKLCH-powered design system for Next.js — built on Tailwind CSS v4, Base UI, and Atomic Design principles.",
  "license": "MIT",
  "author": "SubstrateUI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MikeNotThePope/substrateui.git"
  },
  "homepage": "https://www.substrateui.dev/",
  "keywords": [
    "design-system",
    "react",
    "nextjs",
    "tailwindcss",
    "base-ui",
    "components",
    "ui"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./organisms": {
      "types": "./dist/organisms.d.ts",
      "import": "./dist/organisms.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "next dev",
    "prebuild": "bun run build-storybook",
    "build": "next build",
    "prebuild:lib": "bun run audit:contrast && bun run audit:direction",
    "build:lib": "tsup && cp src/styles/tokens.css dist/styles.css",
    "start": "next start",
    "lint": "eslint",
    "audit:contrast": "tsx scripts/audit-contrast.ts",
    "audit:direction": "tsx scripts/audit-direction.ts",
    "audit:stories": "tsx scripts/audit-stories.ts",
    "test": "NODE_OPTIONS='--throw-deprecation' vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "test:visual:report": "playwright show-report",
    "snapshots:download": "bun scripts/snapshots.ts download",
    "snapshots:upload": "bun scripts/snapshots.ts upload",
    "snapshots:regenerate": "bash scripts/snapshots-regenerate.sh",
    "scan:deprecations": "tsx scripts/scan-deprecations.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o public/storybook && node .storybook/rewrite-base-paths.mjs",
    "prepublishOnly": "bun run build:lib",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "peerDependencies": {
    "next": ">=15",
    "next-themes": ">=0.4",
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=4"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "next-themes": {
      "optional": true
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.7.0",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.9.0",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-arm64-gnu": "^4.60.1"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/culori": "^4.0.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "culori": "^4.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.1",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "storybook": "^10.3.4",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
